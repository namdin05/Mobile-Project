<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:paddingVertical="16dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="8dp"
        android:background="@color/mdx_text_muted" />

    <TextView android:id="@+id/menu_play" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="?attr/selectableItemBackground" android:paddingHorizontal="24dp" android:paddingVertical="14dp" android:text="Play" android:textColor="@color/mdx_text" android:textSize="16sp" />
    <TextView android:id="@+id/menu_like" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="?attr/selectableItemBackground" android:paddingHorizontal="24dp" android:paddingVertical="14dp" android:text="Like / Unlike" android:textColor="@color/mdx_text" android:textSize="16sp" />
    <TextView android:id="@+id/menu_add_playlist" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="?attr/selectableItemBackground" android:paddingHorizontal="24dp" android:paddingVertical="14dp" android:text="Add to playlist" android:textColor="@color/mdx_text" android:textSize="16sp" />
    <TextView android:id="@+id/menu_comments" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="?attr/selectableItemBackground" android:paddingHorizontal="24dp" android:paddingVertical="14dp" android:text="Open comments" android:textColor="@color/mdx_text" android:textSize="16sp" />
    <TextView android:id="@+id/menu_share" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="?attr/selectableItemBackground" android:paddingHorizontal="24dp" android:paddingVertical="14dp" android:text="Share" android:textColor="@color/mdx_text" android:textSize="16sp" />
    <TextView android:id="@+id/menu_download" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="?attr/selectableItemBackground" android:paddingHorizontal="24dp" android:paddingVertical="14dp" android:text="Download / Remove offline" android:textColor="@color/mdx_text" android:textSize="16sp" />
    <TextView android:id="@+id/menu_remove_playlist" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="?attr/selectableItemBackground" android:paddingHorizontal="24dp" android:paddingVertical="14dp" android:text="Remove from playlist" android:textColor="#FF5252" android:textSize="16sp" />

</LinearLayout>