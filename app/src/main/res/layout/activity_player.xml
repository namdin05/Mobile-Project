<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/spotify_black"
    android:paddingStart="20dp"
    android:paddingTop="20dp"
    android:paddingEnd="20dp"
    android:paddingBottom="20dp">

    <androidx.appcompat.widget.AppCompatImageButton
        android:id="@+id/btnClosePlayer"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_player_action_circle"
        android:contentDescription="@string/player_action_close"
        android:padding="10dp"
        android:src="@android:drawable/ic_menu_close_clear_cancel"
        android:tint="@color/spotify_text_primary"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvPlayerScreenTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/player_now_playing"
        android:textAllCaps="true"
        android:textColor="@color/spotify_text_secondary"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btnClosePlayer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/btnClosePlayer"
        app:layout_constraintTop_toTopOf="@id/btnClosePlayer" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnClosePlayer">

        <LinearLayout
            android:id="@+id/layoutPlayerContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="300dp"
                android:layout_height="300dp"
                app:cardBackgroundColor="@color/spotify_dark_surface"
                app:cardCornerRadius="28dp"
                app:strokeColor="@color/spotify_mid_surface"
                app:strokeWidth="1dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/ivPlayerArtwork"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/player_artwork_desc"
                        android:scaleType="centerCrop"
                        android:src="@drawable/bg_image_placeholder" />

                    <ProgressBar
                        android:id="@+id/progressPlayerBuffering"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_gravity="center"
                        android:visibility="gone" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvPlayerTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="2"
                android:textColor="@color/spotify_text_primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvPlayerSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:ellipsize="end"
                android:gravity="center"
                android:maxLines="2"
                android:textColor="@color/spotify_text_secondary"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/tvPlayerQueueInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:textColor="@color/spotify_green"
                android:textSize="13sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlaybackSpeed"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="16dp"
                android:minWidth="0dp"
                android:text="1.0x"
                android:textAllCaps="false"
                android:textColor="@color/spotify_text_primary"
                app:backgroundTint="@color/spotify_mid_surface"
                app:cornerRadius="20dp"
                app:strokeColor="@color/spotify_green"
                app:strokeWidth="1dp" />

            <SeekBar
                android:id="@+id/seekBarProgress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:max="100"
                android:progress="0" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCurrentTime"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0:00"
                    android:textColor="@color/spotify_text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="@color/spotify_text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btnPlayerPrevious"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_player_action_circle"
                    android:contentDescription="@string/player_action_previous"
                    android:padding="12dp"
                    android:src="@android:drawable/ic_media_previous"
                    android:tint="@color/spotify_text_primary" />

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btnPlayerRewind"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_player_action_circle"
                    android:contentDescription="@string/player_action_rewind_15"
                    android:padding="12dp"
                    android:src="@android:drawable/ic_media_rew"
                    android:tint="@color/spotify_text_primary" />

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btnPlayerPlayPause"
                    android:layout_width="78dp"
                    android:layout_height="78dp"
                    android:layout_marginStart="16dp"
                    android:layout_marginEnd="16dp"
                    android:background="@drawable/bg_player_play_circle"
                    android:contentDescription="@string/player_action_play_pause"
                    android:padding="18dp"
                    android:src="@android:drawable/ic_media_play"
                    android:tint="@color/spotify_black" />

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btnPlayerForward"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_player_action_circle"
                    android:contentDescription="@string/player_action_forward_15"
                    android:padding="12dp"
                    android:src="@android:drawable/ic_media_ff"
                    android:tint="@color/spotify_text_primary" />

                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btnPlayerNext"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_player_action_circle"
                    android:contentDescription="@string/player_action_next"
                    android:padding="12dp"
                    android:src="@android:drawable/ic_media_next"
                    android:tint="@color/spotify_text_primary" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvPlayerEmptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:gravity="center"
                android:lineSpacingExtra="4dp"
                android:text="@string/player_empty_message"
                android:textColor="@color/spotify_text_secondary"
                android:textSize="14sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvLyricsSectionTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:text="@string/lyrics_section_title"
                android:textColor="@color/spotify_text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLyricsPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:clickable="true"
                android:focusable="true"
                app:cardBackgroundColor="@color/spotify_dark_surface"
                app:cardCornerRadius="22dp"
                app:strokeColor="@color/spotify_mid_surface"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvLyricsPreviewMode"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/spotify_green"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <ProgressBar
                            android:id="@+id/progressLyricsPreview"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:layout_marginEnd="10dp"
                            android:visibility="gone" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnOpenLyrics"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:minWidth="0dp"
                            android:text="@string/lyrics_open_fullscreen_button"
                            android:textAllCaps="false"
                            android:textColor="@color/spotify_text_primary"
                            app:backgroundTint="@color/spotify_mid_surface"
                            app:cornerRadius="20dp"
                            app:strokeColor="@color/spotify_green"
                            app:strokeWidth="1dp" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvLyricsPreviewContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:lineSpacingExtra="6dp"
                        android:textColor="@color/spotify_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvLyricsPreviewHint"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:textColor="@color/spotify_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>