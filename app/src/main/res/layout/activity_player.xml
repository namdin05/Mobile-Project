<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_circle_surface"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_back"
                app:tint="@color/mdx_text" />

            <TextView
                android:id="@+id/tv_header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:text="Now Playing"
                android:textColor="@color/mdx_text"
                android:textSize="22sp"
                android:textStyle="bold" />

            <ImageButton
                android:id="@+id/btn_share"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_circle_surface"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_share"
                app:tint="@color/mdx_text" />
        </LinearLayout>

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/img_cover"
            android:layout_width="match_parent"
            android:layout_height="340dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_card"
            android:contentDescription="cover"
            android:scaleType="centerCrop"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Melodix.Cover.Large" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Song title"
            android:textColor="@color/mdx_text"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Artist • Album"
            android:textColor="@color/mdx_primary"
            android:textSize="18sp" />

        <SeekBar
            android:id="@+id/seek_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_elapsed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0:00"
                android:textColor="@color/mdx_text_muted" />

            <TextView
                android:id="@+id/tv_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3:45"
                android:textColor="@color/mdx_text_muted" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_download"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_circle_surface"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_download"
                app:tint="@color/mdx_text" />

            <ImageButton
                android:id="@+id/btn_comments"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="14dp"
                android:background="@drawable/bg_circle_surface"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_comment"
                app:tint="@color/mdx_text" />

            <ImageButton
                android:id="@+id/btn_lyrics"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="14dp"
                android:background="@drawable/bg_circle_surface"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_library"
                app:tint="@color/mdx_text" />

            <ImageButton
                android:id="@+id/btn_speed"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="14dp"
                android:background="@drawable/bg_circle_surface"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_stats"
                app:tint="@color/mdx_text" />

            <ImageButton
                android:id="@+id/btn_timer"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="14dp"
                android:background="@drawable/bg_circle_surface"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_timer"
                app:tint="@color/mdx_text" />

            <ImageButton
                android:id="@+id/btn_loop"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="14dp"
                android:background="@drawable/bg_circle_surface"
                android:padding="10dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_timer"
                app:tint="@color/mdx_text" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_prev"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:background="@drawable/bg_circle_surface"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_prev"
                app:tint="@color/mdx_text" />

            <ImageButton
                android:id="@+id/btn_rewind"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_circle_surface"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_rewind"
                app:tint="@color/mdx_text" />

            <ImageButton
                android:id="@+id/btn_play_pause"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_circle_primary"
                android:padding="16dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_play"
                app:tint="@color/black" />

            <ImageButton
                android:id="@+id/btn_forward"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_circle_surface"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_forward"
                app:tint="@color/mdx_text" />

            <ImageButton
                android:id="@+id/btn_next"
                android:layout_width="54dp"
                android:layout_height="54dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_circle_surface"
                android:padding="12dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_next"
                app:tint="@color/mdx_text" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="Lyrics"
            android:textColor="@color/mdx_text"
            android:textSize="22sp"
            android:textStyle="bold" />

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="200dp"> <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_lyrics"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

            <View
                android:id="@+id/view_lyrics_click_overlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clickable="true"
                android:focusable="true"
                android:background="@android:color/transparent" />
        </FrameLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_ai_summary"
            style="@style/Widget.Melodix.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:text="AI Summary from Comments" />

        <TextView
            android:id="@+id/tv_ai_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_card"
            android:padding="14dp"
            android:textColor="@color/mdx_text_secondary" />
    </LinearLayout>
</ScrollView>