<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:paddingVertical="16dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="8dp"
        android:background="@color/mdx_text_muted" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingVertical="10dp"
        android:text="Playback speed"
        android:textColor="@color/mdx_text"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView android:id="@+id/menu_speed_05" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="?attr/selectableItemBackground" android:paddingHorizontal="24dp" android:paddingVertical="14dp" android:text="0.5x" android:textColor="@color/mdx_text" android:textSize="16sp" />
    <TextView android:id="@+id/menu_speed_10" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="?attr/selectableItemBackground" android:paddingHorizontal="24dp" android:paddingVertical="14dp" android:text="1.0x" android:textColor="@color/mdx_text" android:textSize="16sp" />
    <TextView android:id="@+id/menu_speed_125" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="?attr/selectableItemBackground" android:paddingHorizontal="24dp" android:paddingVertical="14dp" android:text="1.25x" android:textColor="@color/mdx_text" android:textSize="16sp" />
    <TextView android:id="@+id/menu_speed_15" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="?attr/selectableItemBackground" android:paddingHorizontal="24dp" android:paddingVertical="14dp" android:text="1.5x" android:textColor="@color/mdx_text" android:textSize="16sp" />
    <TextView android:id="@+id/menu_speed_20" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="?attr/selectableItemBackground" android:paddingHorizontal="24dp" android:paddingVertical="14dp" android:text="2.0x" android:textColor="@color/mdx_text" android:textSize="16sp" />
</LinearLayout>