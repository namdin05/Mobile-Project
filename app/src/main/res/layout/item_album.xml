<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="156dp"
    android:layout_height="wrap_content"
    android:layout_marginEnd="16dp"
    android:orientation="vertical">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardAlbumRoot"
        android:layout_width="match_parent"
        android:layout_height="156dp"
        android:clickable="true"
        android:focusable="true"
        app:cardBackgroundColor="@color/spotify_dark_surface"
        app:cardCornerRadius="18dp"
        app:strokeColor="@color/spotify_mid_surface"
        app:strokeWidth="1dp">

        <ImageView
            android:id="@+id/ivAlbumCover"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/home_album_cover_desc"
            android:scaleType="centerCrop"
            android:src="@drawable/bg_image_placeholder" />
    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/tvAlbumTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="@color/spotify_text_primary"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvAlbumSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:ellipsize="end"
        android:maxLines="2"
        android:textColor="@color/spotify_text_secondary"
        android:textSize="13sp" />

</LinearLayout>