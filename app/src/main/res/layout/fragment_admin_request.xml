<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/melodix_bg_dark"
    tools:context=".View.admin.AdminRequestsFragment">

    <ImageView
        android:id="@+id/btnMenu"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_marginStart="20dp"
        android:layout_marginTop="24dp"
        android:src="@drawable/ic_menu"
        app:tint="@color/melodix_accent_green"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Melodix Admin"
        android:textColor="@color/melodix_accent_green"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginStart="16dp"
        app:layout_constraintBottom_toBottomOf="@+id/btnMenu"
        app:layout_constraintStart_toEndOf="@+id/btnMenu"
        app:layout_constraintTop_toTopOf="@+id/btnMenu" />

    <ImageView
        android:id="@+id/imgProfile"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/circle_bg"
        android:src="@drawable/ic_person"
        app:tint="@color/melodix_text_secondary"
        app:layout_constraintBottom_toBottomOf="@+id/btnMenu"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/btnMenu" />

    <TextView
        android:id="@+id/tvModerationLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="MODERATION"
        android:textColor="@color/melodix_accent_green"
        android:textSize="10sp"
        android:letterSpacing="0.1"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@+id/btnMenu"
        app:layout_constraintTop_toBottomOf="@+id/btnMenu" />

    <TextView
        android:id="@+id/tvPageTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="New Song Requests"
        android:textColor="@color/melodix_text_primary"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="@+id/tvModerationLabel"
        app:layout_constraintTop_toBottomOf="@+id/tvModerationLabel" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBulkApprove"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginEnd="20dp"
        android:text="Bulk Approve"
        android:textColor="@color/melodix_bg_dark"
        android:textSize="12sp"
        android:textStyle="bold"
        app:backgroundTint="@color/melodix_accent_green"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toBottomOf="@+id/tvPageTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tvPageTitle" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="20dp"
        app:cardBackgroundColor="@color/melodix_card_bg"
        app:cardCornerRadius="16dp"
        app:strokeWidth="0dp"
        app:layout_constraintTop_toBottomOf="@+id/tvPageTitle">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp">

            <TextView
                android:id="@+id/tvPendingLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pending Approval"
                android:textColor="@color/melodix_text_secondary"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:id="@+id/tvPendingCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="124"
                android:textColor="@color/melodix_accent_green"
                android:textSize="22sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ProgressBar
                android:id="@+id/progressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="12dp"
                android:max="100"
                android:progress="65"
                android:progressTint="@color/melodix_accent_green"
                android:progressBackgroundTint="@color/melodix_bg_dark"
                app:layout_constraintTop_toBottomOf="@+id/tvPendingCount" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@+id/progressBar">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AVG. WAIT"
                        android:textSize="10sp"
                        android:textColor="@color/melodix_text_secondary"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="14m 20s"
                        android:textStyle="bold"
                        android:textColor="@color/melodix_text_primary"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FLAGGED %"
                        android:textSize="10sp"
                        android:textColor="@color/melodix_text_secondary"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4.2%"
                        android:textStyle="bold"
                        android:textColor="#FCA5A5"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSongRequests"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:clipToPadding="false"
        android:paddingBottom="20dp"
        app:layout_constraintBottom_toTopOf="@+id/cardPlayer"
        app:layout_constraintTop_toBottomOf="@+id/cardStats"
        tools:listitem="@layout/item_song_request" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardPlayer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:visibility="gone"
        app:cardBackgroundColor="@color/melodix_card_bg"
        app:cardCornerRadius="16dp"
        app:strokeWidth="1dp"
        app:strokeColor="#2A3C33"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/tvPlayerStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:text="Đang chuẩn bị phát..."
            android:textAlignment="center"
            android:textStyle="bold"
            android:textColor="@color/melodix_accent_green"/>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>