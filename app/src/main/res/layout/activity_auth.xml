<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/spotify_black">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvBrand"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_name"
                android:textAllCaps="true"
                android:textColor="@color/spotify_text_primary"
                android:textSize="38sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:lineSpacingExtra="2dp"
                android:text="@string/auth_title"
                android:textColor="@color/spotify_text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/auth_subtitle"
                android:textColor="@color/spotify_text_secondary"
                android:textSize="14sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardBackgroundColor="@color/spotify_dark_surface"
                app:cardCornerRadius="24dp"
                app:strokeColor="@color/spotify_mid_surface"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTabLogin"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:text="@string/auth_login_tab"
                            android:textAllCaps="false"
                            android:textColor="@color/spotify_black"
                            app:backgroundTint="@color/spotify_green"
                            app:cornerRadius="16dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTabRegister"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:text="@string/auth_register_tab"
                            android:textAllCaps="false"
                            android:textColor="@color/spotify_text_primary"
                            app:backgroundTint="@color/spotify_mid_surface"
                            app:cornerRadius="16dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutLoginSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auth_login_heading"
                            android:textColor="@color/spotify_text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:hint="@string/auth_email_hint"
                            app:boxBackgroundColor="@color/spotify_mid_surface"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusBottomEnd="18dp"
                            app:boxCornerRadiusBottomStart="18dp"
                            app:boxCornerRadiusTopEnd="18dp"
                            app:boxCornerRadiusTopStart="18dp"
                            app:boxStrokeColor="@color/spotify_green"
                            app:hintTextColor="@color/spotify_text_secondary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etLoginEmail"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textEmailAddress"
                                android:textColor="@color/spotify_text_primary"
                                android:textColorHint="@color/spotify_text_secondary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:hint="@string/auth_password_hint"
                            app:boxBackgroundColor="@color/spotify_mid_surface"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusBottomEnd="18dp"
                            app:boxCornerRadiusBottomStart="18dp"
                            app:boxCornerRadiusTopEnd="18dp"
                            app:boxCornerRadiusTopStart="18dp"
                            app:boxStrokeColor="@color/spotify_green"
                            app:endIconMode="password_toggle"
                            app:hintTextColor="@color/spotify_text_secondary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etLoginPassword"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPassword"
                                android:textColor="@color/spotify_text_primary"
                                android:textColorHint="@color/spotify_text_secondary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnLogin"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="18dp"
                            android:text="@string/auth_login_button"
                            android:textAllCaps="false"
                            android:textColor="@color/spotify_black"
                            app:backgroundTint="@color/spotify_green"
                            app:cornerRadius="26dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="18dp"
                            android:gravity="center"
                            android:text="@string/auth_or_divider"
                            android:textColor="@color/spotify_text_secondary"
                            android:textSize="13sp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnGoogle"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="16dp"
                            android:text="@string/auth_google_button"
                            android:textAllCaps="false"
                            android:textColor="@color/spotify_text_primary"
                            app:backgroundTint="@color/spotify_mid_surface"
                            app:cornerRadius="26dp"
                            app:strokeColor="@color/spotify_green"
                            app:strokeWidth="1dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnFacebook"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="12dp"
                            android:text="@string/auth_facebook_button"
                            android:textAllCaps="false"
                            android:textColor="@color/spotify_text_primary"
                            app:backgroundTint="@color/spotify_mid_surface"
                            app:cornerRadius="26dp"
                            app:strokeColor="@color/spotify_green"
                            app:strokeWidth="1dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutRegisterSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/auth_register_heading"
                            android:textColor="@color/spotify_text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:hint="@string/auth_full_name_hint"
                            app:boxBackgroundColor="@color/spotify_mid_surface"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusBottomEnd="18dp"
                            app:boxCornerRadiusBottomStart="18dp"
                            app:boxCornerRadiusTopEnd="18dp"
                            app:boxCornerRadiusTopStart="18dp"
                            app:boxStrokeColor="@color/spotify_green"
                            app:hintTextColor="@color/spotify_text_secondary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etRegisterFullName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPersonName"
                                android:textColor="@color/spotify_text_primary"
                                android:textColorHint="@color/spotify_text_secondary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:hint="@string/auth_email_hint"
                            app:boxBackgroundColor="@color/spotify_mid_surface"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusBottomEnd="18dp"
                            app:boxCornerRadiusBottomStart="18dp"
                            app:boxCornerRadiusTopEnd="18dp"
                            app:boxCornerRadiusTopStart="18dp"
                            app:boxStrokeColor="@color/spotify_green"
                            app:hintTextColor="@color/spotify_text_secondary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etRegisterEmail"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textEmailAddress"
                                android:textColor="@color/spotify_text_primary"
                                android:textColorHint="@color/spotify_text_secondary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:hint="@string/auth_password_hint"
                            app:boxBackgroundColor="@color/spotify_mid_surface"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusBottomEnd="18dp"
                            app:boxCornerRadiusBottomStart="18dp"
                            app:boxCornerRadiusTopEnd="18dp"
                            app:boxCornerRadiusTopStart="18dp"
                            app:boxStrokeColor="@color/spotify_green"
                            app:endIconMode="password_toggle"
                            app:hintTextColor="@color/spotify_text_secondary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etRegisterPassword"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPassword"
                                android:textColor="@color/spotify_text_primary"
                                android:textColorHint="@color/spotify_text_secondary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="14dp"
                            android:hint="@string/auth_confirm_password_hint"
                            app:boxBackgroundColor="@color/spotify_mid_surface"
                            app:boxBackgroundMode="outline"
                            app:boxCornerRadiusBottomEnd="18dp"
                            app:boxCornerRadiusBottomStart="18dp"
                            app:boxCornerRadiusTopEnd="18dp"
                            app:boxCornerRadiusTopStart="18dp"
                            app:boxStrokeColor="@color/spotify_green"
                            app:endIconMode="password_toggle"
                            app:hintTextColor="@color/spotify_text_secondary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etRegisterConfirmPassword"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPassword"
                                android:textColor="@color/spotify_text_primary"
                                android:textColorHint="@color/spotify_text_secondary" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnRegister"
                            android:layout_width="match_parent"
                            android:layout_height="52dp"
                            android:layout_marginTop="18dp"
                            android:text="@string/auth_register_button"
                            android:textAllCaps="false"
                            android:textColor="@color/spotify_black"
                            app:backgroundTint="@color/spotify_green"
                            app:cornerRadius="26dp" />
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <FrameLayout
        android:id="@+id/layoutLoadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center" />
    </FrameLayout>

</FrameLayout>