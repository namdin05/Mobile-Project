<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_card"
    android:orientation="vertical"
    android:paddingVertical="16dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="8dp"
        android:background="@color/mdx_text_muted" />

    <TextView
        android:id="@+id/btn_rename_playlist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:paddingHorizontal="24dp"
        android:paddingVertical="14dp"
        android:text="Rename playlist"
        android:textColor="@color/mdx_text"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/btn_change_cover"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:paddingHorizontal="24dp"
        android:paddingVertical="14dp"
        android:text="Change cover"
        android:textColor="@color/mdx_text"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/btn_share_playlist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:paddingHorizontal="24dp"
        android:paddingVertical="14dp"
        android:text="Share"
        android:textColor="@color/mdx_text"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/btn_delete_playlist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="?attr/selectableItemBackground"
        android:paddingHorizontal="24dp"
        android:paddingVertical="14dp"
        android:text="Delete playlist"
        android:textColor="#FF5252"
        android:textSize="16sp" />

</LinearLayout>