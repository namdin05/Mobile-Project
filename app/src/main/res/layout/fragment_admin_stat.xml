<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/melodix_accent_green_dark"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/tvLastSync"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="30dp"
            android:text="Lastest update: Just now"
            android:textColor="@color/melodix_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardUsersBanner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="20dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardBackgroundColor="@color/melodix_card_bg"
            app:cardCornerRadius="16dp"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toBottomOf="@id/tvLastSync">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <ImageView
                        android:id="@+id/iconBannerUser"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_person"
                        app:tint="@color/melodix_accent_green" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:layout_toEndOf="@id/iconBannerUser"
                        android:text="Total Network Users"
                        android:textColor="@color/melodix_text_secondary"
                        android:textSize="14sp" />

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="@color/melodix_text_secondary" />
                    <TextView
                        android:id="@+id/tvTotalUsers"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/iconBannerUser"
                        android:layout_marginTop="8dp"
                        android:text="1,550"
                        android:textColor="@color/melodix_text_primary"
                        android:textSize="32sp"
                        android:textStyle="bold" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="#1AFFFFFF" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:baselineAligned="false"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Listeners"
                            android:textColor="@color/melodix_text_secondary"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tvTotalListeners"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="..."
                            android:textColor="@color/melodix_text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Artists"
                            android:textColor="@color/melodix_text_secondary"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tvTotalArtists"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="..."
                            android:textColor="@color/melodix_text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Admins"
                            android:textColor="@color/melodix_text_secondary"
                            android:textSize="12sp" />
                        <TextView
                            android:id="@+id/tvTotalAdmins"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="..."
                            android:textColor="@color/melodix_text_primary"
                            android:textSize="18sp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvContentTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:text="Content Overview"
            android:textColor="@color/melodix_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardUsersBanner" />

        <GridLayout
            android:id="@+id/glContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="12dp"
            android:columnCount="2"
            android:rowCount="2"
            app:layout_constraintTop_toBottomOf="@id/tvContentTitle">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSongs"
                style="@style/MelodixDashCard">
                <RelativeLayout style="@style/MelodixDashContent">
                    <ImageView android:id="@+id/iconSongs" style="@style/MelodixDashIcon" android:src="@drawable/ic_music" />
                    <TextView style="@style/MelodixDashLabel" android:layout_toEndOf="@id/iconSongs" android:text="Songs" />
                    <ImageView style="@style/MelodixDashArrow" />
                    <TextView android:id="@+id/tvTotalSongs" style="@style/MelodixDashValue" android:layout_below="@id/iconSongs" android:text="8,930" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardAlbums"
                style="@style/MelodixDashCard">
                <RelativeLayout style="@style/MelodixDashContent">
                    <ImageView android:id="@+id/iconAlbums" style="@style/MelodixDashIcon" android:src="@drawable/ic_dashboard" />
                    <TextView style="@style/MelodixDashLabel" android:layout_toEndOf="@id/iconAlbums" android:text="Albums" />
                    <ImageView style="@style/MelodixDashArrow" />
                    <TextView android:id="@+id/tvTotalAlbums" style="@style/MelodixDashValue" android:layout_below="@id/iconAlbums" android:text="1,245" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardGenres"
                style="@style/MelodixDashCard">
                <RelativeLayout style="@style/MelodixDashContent">
                    <ImageView android:id="@+id/iconGenres" style="@style/MelodixDashIcon" android:src="@drawable/ic_menu" />
                    <TextView style="@style/MelodixDashLabel" android:layout_toEndOf="@id/iconGenres" android:text="Genres" />
                    <ImageView style="@style/MelodixDashArrow" />
                    <TextView android:id="@+id/tvTotalGenres" style="@style/MelodixDashValue" android:layout_below="@id/iconGenres" android:text="24" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPlaylists"
                style="@style/MelodixDashCard">
                <RelativeLayout style="@style/MelodixDashContent">
                    <ImageView android:id="@+id/iconPlaylists" style="@style/MelodixDashIcon" android:src="@drawable/ic_menu" />
                    <TextView style="@style/MelodixDashLabel" android:layout_toEndOf="@id/iconPlaylists" android:text="Playlists" />
                    <ImageView style="@style/MelodixDashArrow" />
                    <TextView android:id="@+id/tvTotalPlaylists" style="@style/MelodixDashValue" android:layout_below="@id/iconPlaylists" android:text="512" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

        </GridLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/melodix_card_bg"
            app:cardCornerRadius="16dp"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toBottomOf="@id/glContent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="System Insights"
                    android:textColor="@color/melodix_accent_green"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="2dp"
                    android:layout_marginTop="4dp"
                    android:background="@color/melodix_accent_green" />

                <TextView
                    android:id="@+id/tvAppStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:lineSpacingExtra="6dp"
                    android:text="• Supabase Edge Functions: Active\n• Semantic Kernel Agent: Idle\n• Core API (Node.js): Operational\n• Active Realtime Triggers: 3"
                    android:textColor="@color/melodix_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>