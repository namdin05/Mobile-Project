<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mdx_bg"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/tvHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:layout_marginTop="24dp"
            android:text="Latest Update"
            android:textColor="@color/mdx_text"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvLastSync"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="20dp"
            android:text="Last sync: 2 mins ago"
            android:textColor="@color/mdx_text_secondary"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvHeader" />

        <GridLayout
            android:id="@+id/glDashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp"
            android:layout_marginTop="16dp"
            android:columnCount="2"
            android:rowCount="3"
            app:layout_constraintTop_toBottomOf="@id/tvLastSync">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardUsers"
                style="@style/MelodixDashCard">
                <RelativeLayout style="@style/MelodixDashContent">
                    <ImageView android:id="@+id/icon1" style="@style/MelodixDashIcon" android:src="@drawable/ic_person" />
                    <TextView style="@style/MelodixDashLabel" android:layout_toEndOf="@id/icon1" android:text="Users" />
                    <ImageView style="@style/MelodixDashArrow" />
                    <TextView android:id="@+id/tvTotalUsers" style="@style/MelodixDashValue" android:layout_below="@id/icon1" android:text="1,204" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardArtists"
                style="@style/MelodixDashCard">
                <RelativeLayout style="@style/MelodixDashContent">
                    <ImageView android:id="@+id/icon2" style="@style/MelodixDashIcon" android:src="@drawable/ic_music" />
                    <TextView style="@style/MelodixDashLabel" android:layout_toEndOf="@id/icon2" android:text="Artists" />
                    <ImageView style="@style/MelodixDashArrow" />
                    <TextView android:id="@+id/tvTotalArtists" style="@style/MelodixDashValue" android:layout_below="@id/icon2" android:text="342" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSongs"
                style="@style/MelodixDashCard">
                <RelativeLayout style="@style/MelodixDashContent">
                    <ImageView android:id="@+id/icon3" style="@style/MelodixDashIcon" android:src="@drawable/ic_dashboard" />
                    <TextView style="@style/MelodixDashLabel" android:layout_toEndOf="@id/icon3" android:text="Songs" />
                    <ImageView style="@style/MelodixDashArrow" />
                    <TextView android:id="@+id/tvTotalSongs" style="@style/MelodixDashValue" android:layout_below="@id/icon3" android:text="8,930" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPlaylists"
                style="@style/MelodixDashCard">
                <RelativeLayout style="@style/MelodixDashContent">
                    <ImageView android:id="@+id/icon4" style="@style/MelodixDashIcon" android:src="@drawable/ic_menu" />
                    <TextView style="@style/MelodixDashLabel" android:layout_toEndOf="@id/icon4" android:text="Playlists" />
                    <ImageView style="@style/MelodixDashArrow" />
                    <TextView android:id="@+id/tvTotalPlaylists" style="@style/MelodixDashValue" android:layout_below="@id/icon4" android:text="512" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardListens"
                style="@style/MelodixDashCard">
                <RelativeLayout style="@style/MelodixDashContent">
                    <ImageView android:id="@+id/icon5" style="@style/MelodixDashIcon" android:src="@drawable/ic_menu" />
                    <TextView style="@style/MelodixDashLabel" android:layout_toEndOf="@id/icon5" android:text="Listens" />
                    <ImageView style="@style/MelodixDashArrow" />
                    <TextView android:id="@+id/tvTotalListens" style="@style/MelodixDashValue" android:layout_below="@id/icon5" android:text="1.2M" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDownloads"
                style="@style/MelodixDashCard">
                <RelativeLayout style="@style/MelodixDashContent">
                    <ImageView android:id="@+id/icon6" style="@style/MelodixDashIcon" android:src="@drawable/ic_dashboard" />
                    <TextView style="@style/MelodixDashLabel" android:layout_toEndOf="@id/icon6" android:text="Offline" />
                    <ImageView style="@style/MelodixDashArrow" />
                    <TextView android:id="@+id/tvTotalDownloads" style="@style/MelodixDashValue" android:layout_below="@id/icon6" android:text="45K" />
                </RelativeLayout>
            </com.google.android.material.card.MaterialCardView>
        </GridLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="16dp"
            app:cardBackgroundColor="@color/mdx_card"
            app:cardCornerRadius="16dp"
            app:strokeWidth="0dp"
            app:layout_constraintTop_toBottomOf="@id/glDashboard">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="System Insights"
                    android:textColor="@color/mdx_primary"
                    android:textStyle="bold"
                    android:textSize="16sp"/>

                <View
                    android:layout_width="40dp"
                    android:layout_height="2dp"
                    android:layout_marginTop="4dp"
                    android:background="@color/mdx_primary"/>

                <TextView
                    android:id="@+id/tvAppStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:lineSpacingExtra="6dp"
                    android:text="• Total Streams: 4,502,310\n• Active Sessions: 128 users\n• Server Status: Operational (99.9%)\n• Database: PostgreSQL (Supabase)\n• AI Summaries Generated: 1,240"
                    android:textColor="@color/mdx_text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>