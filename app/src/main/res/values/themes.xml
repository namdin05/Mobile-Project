<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Melodix" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/mdx_primary</item>
        <item name="colorPrimaryVariant">@color/mdx_primary_dark</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/mdx_primary</item>
        <item name="android:statusBarColor">@color/mdx_bg</item>
        <item name="android:navigationBarColor">@color/mdx_bg</item>
        <item name="android:windowBackground">@color/mdx_bg</item>
        <item name="colorSurface">@color/mdx_surface</item>
        <item name="colorOnSurface">@color/mdx_text</item>
        <item name="android:textColor">@color/mdx_text</item>
        <item name="materialButtonStyle">@style/Widget.Melodix.Button</item>
        <item name="bottomNavigationStyle">@style/Widget.Melodix.BottomNav</item>
        <item name="chipStyle">@style/Widget.Melodix.Chip</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Theme.Melodix.Splash" parent="Theme.Melodix">
        <item name="android:windowBackground">@color/mdx_bg</item>
    </style>

    <style name="Widget.Melodix.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">18dp</item>
        <item name="backgroundTint">@color/mdx_primary</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="Widget.Melodix.OutlinedButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">18dp</item>
        <item name="strokeColor">@color/mdx_line</item>
        <item name="android:textColor">@color/mdx_text</item>
    </style>

    <style name="Widget.Melodix.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView.Colored">
        <item name="itemIconTint">@color/bottom_nav_colors</item>
        <item name="itemTextColor">@color/bottom_nav_colors</item>
        <item name="android:background">@color/mdx_bg_secondary</item>
    </style>

    <style name="Widget.Melodix.Chip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="android:textColor">@color/mdx_text</item>
        <item name="chipBackgroundColor">@color/chip_bg_state</item>
        <item name="checkedIconVisible">false</item>
    </style>

    <style name="TextAppearance.Melodix.Title" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/mdx_text</item>
    </style>

    <style name="TextAppearance.Melodix.Section" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/mdx_text</item>
    </style>

    <style name="TextAppearance.Melodix.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/mdx_text_secondary</item>
    </style>
    <style name="BottomSheetDialogTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
    </style>

    <style name="BottomSheetTheme" parent="Theme.Design.Light.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/BottomSheetStyle</item>
    </style>

    <style name="BottomSheetStyle" parent="Widget.Design.BottomSheet.Modal">
        <item name="android:background">@android:color/transparent</item>
    </style>

    <style name="ShapeAppearanceOverlay.Melodix.Cover.Small">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearanceOverlay.Melodix.Cover.Large">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>
    <style name="ShapeAppearanceOverlay.Melodix.Cover" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="Theme.Melodix.PopupMenu" parent="Theme.AppCompat.DayNight">
        <item name="android:textColor">@color/mdx_text</item>
        <item name="android:popupBackground">@drawable/bg_mini_player</item>
    </style>
</resources>
